# =============================================================================
# Docker Ignore File
# =============================================================================
# Files and directories listed here will NOT be copied to the Docker image
# This reduces build time and image size
# =============================================================================

# Dependencies (will be installed in container)
node_modules
.pnpm-store

# Build outputs (will be generated in container)
.next
out
build
dist

# Development files
.git
.gitignore
.dockerignore

# IDE/Editor files
.vscode
.idea
*.swp
*.swo
.DS_Store

# Environment files (use Docker environment variables instead)
.env
.env.local
.env.development
.env.production
.env*.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Testing
coverage
.nyc_output
jest.config.*
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__

# Documentation (not needed in container)
README.md
CHANGELOG.md
LICENSE
docs

# Docker files (prevent recursive copy)
Dockerfile*
docker-compose*.yml
.docker

# Misc
*.md
!README.md
.turbo
.vercel
